{% extends 'template.html.twig' %}

{% block body %}

    <div class="row">
        <div class="medium-12 large-12 columns">
            <h4>Hóspedes</h4>
            <div class="medium-3  columns"><a class="button" href="">ADICIONAR HÓSPEDE</a></div>

            <table class="stack">
                <thead>
                    <tr>
                      <th width="200">Name</th>
                      <th width="200">Email</th>
                      <th width="200">Ações</th>
                    </tr>
                </thead>
                <tbody>
                {% for hospede in hospedes %}
                    <tr>
                        <td>{{ hospede.titulo | capitalize }}. {{ hospede.nome }}</td>
                        <td>{{ hospede.email }}</td>
                        <td>
                            <a class="hollow button" href="">EDITAR</a>
                            <a class="hollow button warning" href="">RESERVAR QUARTO</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

{% endblock %}
